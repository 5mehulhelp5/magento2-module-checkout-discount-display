<?xml version="1.0"?>
<ruleset name="PixelPerfect CheckoutDiscountDisplay">
    <description>Uses the shared PixelPerfect standard (pixelperfectat/coding-standard).</description>
    <config name="ignore_warnings_on_exit" value="1"/>
    <!-- Module requires PHP ^8.3; allow readonly classes (PHP 8.2+) -->
    <config name="testVersion" value="8.2-"/>

    <file>.</file>
    <exclude-pattern>*/Test/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/docs/*</exclude-pattern>
    <exclude-pattern>*/view/*</exclude-pattern>
    <exclude-pattern>*.sync-conflict-*</exclude-pattern>

    <rule ref="PixelPerfect"/>
</ruleset>
